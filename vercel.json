{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/analyze-card.js": {
      "maxDuration": 60
    },
    "api/recommend-card.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
