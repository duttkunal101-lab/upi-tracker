# Copy this file to ".env" and fill in your values (the .env file is gitignored).

# --- Required for the AI card lookup ---
# Get a key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional: the "first 100 people" early-access gate + live counter ---
# Leave BOTH blank to disable the gate (the app stays fully usable; the counter
# is simply hidden). To enable it, create a free Upstash Redis database at
# https://console.upstash.com and copy its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# How many people get early access. Defaults to 100 if unset. Set it to 2 for
# quick testing, or any number for a bigger round.
CARDWISE_CAP=100

# --- Optional: real card PHOTOS from Google image search ---
# Bank LOGOS work automatically (no key needed). To also show each card's actual
# photo, create a Google Cloud API key and a Programmable Search Engine with
# "Image search" ON and "Search the entire web" enabled:
#   https://console.cloud.google.com  (enable "Custom Search API", make an API key)
#   https://programmablesearchengine.google.com  (create an engine, copy its ID)
# Free tier is 100 lookups/day. Leave blank to skip photos (the branded card shows).
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
